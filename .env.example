# ====================================================================
# Unified Search - Environment Variables Template
# ====================================================================
#
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# Then load it before running:
#   source .env
#   python3 unified_search.py
#
# ====================================================================

# --------------------------------------------------------------------
# Jira Configuration
# --------------------------------------------------------------------
# Your Jira email (e.g., user@redhat.com)
JIRA_EMAIL="your-email@redhat.com"

# Jira API token (get from: https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN="your-jira-api-token-here"

# --------------------------------------------------------------------
# SFDC/KCS Configuration
# --------------------------------------------------------------------
# Red Hat API offline token (get from: https://access.redhat.com/management/api)
RH_API_OFFLINE_TOKEN="your-offline-token-here"

# --------------------------------------------------------------------
# Slack Configuration
# --------------------------------------------------------------------
# Slack xoxc token (from browser cookies)
SLACK_XOXC_TOKEN="xoxc-your-token-here"

# Slack xoxd token (from browser cookies)
SLACK_XOXD_TOKEN="xoxd-your-token-here"

# --------------------------------------------------------------------
# Notes:
# --------------------------------------------------------------------
# 1. NEVER commit this file with real credentials to git!
# 2. The .env file is already in .gitignore
# 3. Jira URL is hardcoded to: https://redhat.atlassian.net
# 4. Slack workspace is hardcoded to: https://redhat.enterprise.slack.com
# --------------------------------------------------------------------
