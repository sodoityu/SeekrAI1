# ====================================================================
# Unified Search - Environment Variables Template
# ====================================================================
#
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# Then load it before running:
#   source .env
#   poetry run python finaltoolMay17/unified_search.py
#
# Or use the UI to enter credentials (recommended - more secure)
# ====================================================================

# --------------------------------------------------------------------
# Jira Configuration
# --------------------------------------------------------------------
# Your Red Hat Jira email
JIRA_EMAIL="your-email@redhat.com"

# Jira API token (get from: https://issues.redhat.com → Account Settings → API tokens)
JIRA_API_TOKEN="your-jira-api-token-here"

# Jira base URL (usually this default)
JIRA_BASE_URL="https://issues.redhat.com"

# --------------------------------------------------------------------
# SFDC (Salesforce / Red Hat Customer Portal) Configuration
# --------------------------------------------------------------------
# Red Hat API offline token (get from: https://access.redhat.com/management/api)
RH_API_OFFLINE_TOKEN="your-offline-token-here"

# --------------------------------------------------------------------
# Slack Configuration
# --------------------------------------------------------------------
# Slack xoxc token (from browser cookies - see INSTALLATION_GUIDE.md)
SLACK_XOXC_TOKEN="xoxc-your-token-here"

# Slack xoxd token (from browser cookies - see INSTALLATION_GUIDE.md)
SLACK_XOXD_TOKEN="xoxd-your-token-here"

# Slack workspace URL
SLACK_WORKSPACE_URL="https://redhat.enterprise.slack.com"

# Logs channel ID (for filtering debug messages)
LOGS_CHANNEL_ID="C0AKQ7SD0RZ"

# --------------------------------------------------------------------
# Optional: Flask Configuration
# --------------------------------------------------------------------
# Secret key for Flask sessions (change this for production!)
FLASK_SECRET_KEY="change-this-to-a-random-string-in-production"

# Flask environment (development or production)
FLASK_ENV="development"

# Port to run on (default: 5500)
PORT="5500"

# --------------------------------------------------------------------
# Notes:
# --------------------------------------------------------------------
# 1. NEVER commit this file with real credentials to git!
# 2. The .env file is already in .gitignore
# 3. For persistent credentials, use the UI instead (Settings → Save & Remember)
# 4. UI-saved credentials are stored in .saved_credentials.json (not in git)
# 5. Environment variables take precedence over .saved_credentials.json
# --------------------------------------------------------------------

# ====================================================================
# How to Get Credentials
# ====================================================================
#
# JIRA_API_TOKEN:
#   1. Go to: https://issues.redhat.com
#   2. Click profile → Account Settings → Security
#   3. Create API token
#   4. Copy the token
#
# RH_API_OFFLINE_TOKEN:
#   1. Go to: https://access.redhat.com/management/api
#   2. Click "Generate Token"
#   3. Copy the offline token
#
# SLACK_XOXC_TOKEN & SLACK_XOXD_TOKEN:
#   1. Open Slack in browser (Chrome/Firefox)
#   2. Press F12 (Developer Tools)
#   3. Go to Application tab → Cookies
#   4. Find cookie named "d" → This is SLACK_XOXD_TOKEN
#   5. Go to Local Storage → Find "xoxc-..." → This is SLACK_XOXC_TOKEN
#
# ====================================================================
